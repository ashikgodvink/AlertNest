import { COLORS } from '../utils/colors';

export default function ProgressChart({ pct = 0, onViewAll }) {
  // Using CSS variables directly
  // Using CSS variables directly
  // Using CSS variables directly
  // Using CSS variables directly

  const r = 44, circ = 2 * Math.PI * r;
  const dash = (Math.min(pct, 100) / 100) * circ;

  return (
    <div style={{ background: '#0d2b1f', border: `1px solid var(--border)`, padding: '24px 26px', display: 'flex', flexDirection: 'column' }}>
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '20px' }}>
        <span style={{ fontSize: '10px', fontWeight: '600', letterSpacing: '0.15em', textTransform: 'uppercase', color: 'var(--muted)' }}>Resolution Rate</span>
        <button onClick={onViewAll} style={{ background: 'transparent', color: 'var(--gold)', border: `1px solid var(--border)`, padding: '4px 12px', fontSize: '10px', fontWeight: '600', cursor: 'pointer', letterSpacing: '0.1em', textTransform: 'uppercase' }}>
          View All →
        </button>
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: '24px' }}>
        <svg width="110" height="110" viewBox="0 0 130 130" style={{ flexShrink: 0 }}>
          <circle cx="65" cy="65" r={r} fill="none" stroke={BORDER} strokeWidth="8" />
          <circle cx="65" cy="65" r={r} fill="none" stroke={GOLD} strokeWidth="8"
            strokeDasharray={`${dash} ${circ}`} strokeLinecap="butt" transform="rotate(-90 65 65)" />
          <text x="65" y="68" textAnchor="middle" fontSize="22" fontWeight="300" fill={TEXT}>{pct}%</text>
        </svg>
        <div>
          <p style={{ margin: '0 0 4px', fontSize: '28px', fontWeight: '300', color: 'var(--text)', letterSpacing: '-0.5px' }}>{pct}%</p>
          <p style={{ margin: 0, fontSize: '11px', color: 'var(--muted)' }}>of incidents resolved</p>
        </div>
      </div>
    </div>
  );
}
